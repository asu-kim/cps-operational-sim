target C {
  platform: {
    name: "rp2040",
    board: "pololu_3pi_2040_robot"
  },
  single-threaded: true
}

reactor EncoderLogFields {
  input encoder_deg: int32_t
  input delta_encoder_deg: int32_t
  input distance_m: float
  input cmd_milli: int

  output logged_encoder_deg: int32_t
  output logged_delta_encoder_deg: int32_t
  output logged_distance_m: float
  output logged_cmd_milli: int

  reaction(encoder_deg, delta_encoder_deg, distance_m, cmd_milli)
      -> logged_encoder_deg, logged_delta_encoder_deg, logged_distance_m, logged_cmd_milli {=
    lf_set(logged_encoder_deg, encoder_deg->value);
    lf_set(logged_delta_encoder_deg, delta_encoder_deg->value);
    lf_set(logged_distance_m, distance_m->value);
    lf_set(logged_cmd_milli, cmd_milli->value);
  =}
}
